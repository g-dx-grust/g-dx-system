# ─── Application ─────────────────────────────────────────────────────────────
# Environment: local | development | staging | production | test
APP_ENV=local
APP_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/gdx
DATABASE_POOL_MAX=10

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth (all three are REQUIRED) ───────────────────────────────────────────
# The app throws a configuration error on startup if any of the following are
# missing. Obtain LARK_CLIENT_ID and LARK_CLIENT_SECRET from the Lark Developer
# Console. LARK_REDIRECT_URI must be registered there as well.

LARK_CLIENT_ID=
LARK_CLIENT_SECRET=

# Must match exactly: <APP_URL>/api/v1/auth/lark/callback
LARK_REDIRECT_URI=http://localhost:3000/api/v1/auth/lark/callback

# Long random string – generate with: openssl rand -hex 32
SESSION_SECRET=dev-session-secret-change-me-in-production

# Override the session cookie name (optional).
# SESSION_COOKIE_NAME=gdx_session

# ─── Queue ────────────────────────────────────────────────────────────────────
QUEUE_PREFIX=gdx
QUEUE_CONCURRENCY=5

# ─── Logging ──────────────────────────────────────────────────────────────────
# Log level: debug | info | warn | error
LOG_LEVEL=info

# Sentry DSN – leave blank to disable error reporting.
SENTRY_DSN=

# ─── Feature flags ────────────────────────────────────────────────────────────
FEATURE_ENABLE_DASHBOARD_V2=false
